# pnpm: usar node_modules plano (sin symlinks).
# Necesario porque el proyecto vive en el recurso de red de WSL (\\wsl.localhost\...)
# accedido desde Windows, donde los symlinks de pnpm no resuelven bien y next queda
# "no reconocido". Hoisted crea un node_modules estilo npm, con los shims .cmd de Windows.
node-linker=hoisted
shamefully-hoist=true
